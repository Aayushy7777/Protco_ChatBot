# CSV Chat Agent - Production Environment Variables

# ─────────────────── Application ───────────────────
APP_NAME=CSV Chat Agent API
APP_VERSION=2.0.0
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────── Ollama LLM ───────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=60

# Models
INTENT_MODEL=mistral:7b
CHAT_MODEL=llama3.1:8b
CHART_MODEL=qwen2.5:7b
SUMMARY_MODEL=llama3.1:8b

# ─────────────────── Embeddings ───────────────────
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─────────────────── Vector Store ───────────────────
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./BACKEND/data/vector_store/chroma_db

# ─────────────────── RAG Configuration ───────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# ─────────────────── File Upload ───────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.csv,.xlsx,.xls

# ─────────────────── Conversation ───────────────────
MAX_CONVERSATION_TURNS=20
CONVERSATION_MEMORY_TYPE=buffer

# ─────────────────── Logging ───────────────────
LOG_FORMAT=json
